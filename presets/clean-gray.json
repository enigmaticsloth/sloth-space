{
  "id": "clean-gray",
  "name": "Clean Gray",
  "description": "Light gray background, black text. Softer than pure white, easier on the eyes for long presentations.",
  "colors": {
    "background": "#F2F2F2",
    "surface": "#E8E8E8",
    "primary": "#111111",
    "secondary": "#555555",
    "accent": "#111111",
    "on_accent": "#FFFFFF",
    "border": "#D0D0D0",
    "table_header_bg": "#E0E0E0",
    "table_header_text": "#111111",
    "table_row_alt": "#EBEBEB"
  },
  "typography": {
    "heading": { "family": "Arial", "weight": 700, "letterSpacing": -0.3 },
    "body": { "family": "Arial", "weight": 400, "lineHeight": 1.6 },
    "caption": { "family": "Arial", "weight": 400, "transform": "none" },
    "scale": [44, 32, 24, 18, 14, 12]
  },
  "spacing": {
    "margin": { "top": 60, "right": 72, "bottom": 52, "left": 72 },
    "gap": 24,
    "paragraph": 14
  },
  "slide": { "width": 1280, "height": 720 },
  "decorations": {
    "divider": { "style": "solid", "color": "#D0D0D0", "thickness": 1 },
    "accentBar": { "enabled": false },
    "pageNumber": { "show": true, "position": "bottom-right", "format": "number" }
  }
}
