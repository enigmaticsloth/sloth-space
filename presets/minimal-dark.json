{
  "id": "minimal-dark",
  "name": "Minimal Dark",
  "description": "Dark background, high contrast, modern feel. Best for: tech demos, product launches, developer talks, evening presentations.",
  "colors": {
    "background": "#0F0F0F",
    "surface": "#1A1A2E",
    "primary": "#F1F1F1",
    "secondary": "#9CA3AF",
    "accent": "#818CF8",
    "on_accent": "#FFFFFF",
    "border": "#2D2D3D"
  },
  "typography": {
    "heading": {
      "family": "Inter",
      "weight": 700,
      "letterSpacing": -0.5
    },
    "body": {
      "family": "Inter",
      "weight": 400,
      "lineHeight": 1.6
    },
    "caption": {
      "family": "Inter",
      "weight": 500,
      "transform": "uppercase"
    },
    "scale": [48, 36, 26, 19, 15, 13]
  },
  "spacing": {
    "margin": { "top": 64, "right": 72, "bottom": 56, "left": 72 },
    "gap": 24,
    "paragraph": 14
  },
  "slide": {
    "width": 1280,
    "height": 720
  },
  "decorations": {
    "divider": { "style": "solid", "thickness": 1 },
    "accentBar": { "enabled": true, "position": "top", "thickness": 3 },
    "pageNumber": { "show": true, "position": "bottom-right", "format": "number" }
  }
}
